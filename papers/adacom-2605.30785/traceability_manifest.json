      ]
    },
    {
      "claim_id": "C1.2",
      "section_id": "1",
      "statement": "Prior context management approaches couple management with agent training, making them impractical for closed-source agents",
      "interpretation_type": "evidence-backed interpretation",
      "research_role": "problem framing",
      "confidence": "high",
      "evidences": [
        {
          "evidence_id": "EC1_2.a",
          "source_kind": "latex_paragraph",
          "source_file": "main.tex",
          "paragraph_id": "P-main-tex-0012",
          "locator_method": "guesstimate",
          "quote_text": "Because these mechanisms require the agent to follow the new context patterns... prior work often couples them with agent training to realize performance gains.",
          "line_start": 75,
          "line_end": 83
        }
      ]
    },
    {
      "claim_id": "C1.3",
      "section_id": "1",
      "statement": "Predefined operations (e.g. summarization) impose a one-size-fits-all strategy despite variation in agents",
      "interpretation_type": "evidence-backed interpretation",
      "research_role": "problem framing",
      "confidence": "high",
      "evidences": [
        {
          "evidence_id": "EC1_3.a",
          "source_kind": "latex_paragraph",
          "source_file": "main.tex",
          "paragraph_id": "P-main-tex-0012",
          "locator_method": "guesstimate",
          "quote_text": "Moreover, predefined operations such as summarization impose a one-size-fits-all strategy despite substantial variation in agents' architectures, training data, and reasoning styles.",
          "line_start": 83,
          "line_end": 85
        }
      ]
    },
    {
      "claim_id": "C2.1",
      "section_id": "2",
      "statement": "AdaCoM achieves architectural decoupling by using an external manager (smaller LLM) to manage context while keeping the agent frozen",
      "interpretation_type": "evidence-backed interpretation",
      "research_role": "method design",
      "confidence": "high",
      "evidences": [
        {
          "evidence_id": "EC2_1.a",
          "source_kind": "latex_paragraph",
          "source_file": "main.tex",
          "paragraph_id": "P-main-tex-0012",
          "locator_method": "guesstimate",
          "quote_text": "architectural decoupling: context management is handled by an external manager, typically a smaller LLM, while the agent itself remains unchanged.",
          "line_start": 89,
          "line_end": 92
        }
      ]
    },
    {
      "claim_id": "C2.2",
      "section_id": "2",
      "statement": "AdaCoM achieves operation-level flexibility by allowing the manager to freely modify any part of the context via a structured JSON action space",
      "interpretation_type": "evidence-backed interpretation",
      "research_role": "method design",
      "confidence": "high",
      "evidences": [
        {
          "evidence_id": "EC2_2.a",
          "source_kind": "latex_paragraph",
          "source_file": "main.tex",
          "paragraph_id": "P-main-tex-0012",
          "locator_method": "guesstimate",
          "quote_text": "operation-level flexibility: instead of committing to predefined operations such as summarization, the manager can freely modify any part of the context",
          "line_start": 92,
          "line_end": 94
        },
        {
          "evidence_id": "EC2_2.b",
